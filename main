# --- SUBMENU DE AUDITORIA (Conforme os detalhes no mapa) ---
def menu_auditoria():
    opcao_auditoria = ""
    while opcao_auditoria != '7':
        print("\n--- [AUDITORIA] ---")
        print("1. Ver Logs") # Registro de atividades 
        print("2. Ver Inconsistências") # Verificação de erros 
        print("3. Gráficos de Votos") # Visualização de dados 
        print("4. Votos por Família/Partido") # Filtros de apuração 
        print("5. Estatísticas de Comparecimento") # Dados de presença 
        print("6. Validação de Integridade") # Checagem de segurança 
        print("7. Voltar")
        
        opcao_auditoria = input("\nSelecione o relatório: ")
        
        match opcao_auditoria:
            case '1': print(">> Lendo arquivos de Log via Python...") 
            case '2': print(">> Cruzando dados no MySQL...") 
            case '3': print(">> Gerando gráficos...")
            case '4': print(">> Filtrando resultados...")
            case '5': print(">> Calculando estatísticas...")
            case '6': print(">> Validando assinaturas digitais...")
            case '7': print(">> Retornando ao menu Votação...")
            case _: print("Opção inválida.")

# --- MENU DE VOTAÇÃO (Ponto central do mapa) ---
def menu_votacao():
    opcao_voto = ""
    while opcao_voto != '4':
        print("\n--- [VOTAÇÃO] ---")
        print("1. Abrir sistema de votação") # Início do fluxo de voto 
        print("2. Auditoria") # Acesso à conferência 
        print("3. Resultados") # Exibição da apuração 
        print("4. Voltar")
        
        opcao_voto = input("\nEscolha: ")
        
        match opcao_voto:
            case '1': print(">> Iniciando interface de voto...")
            case '2': menu_auditoria() # Chama o submenu detalhado acima
            case '3': print(">> Buscando totais no Banco de Dados...") 
            case '4': print(">> Voltando ao início...")
            case _: print("Opção inválida.")

# --- MENU DE GERENCIAMENTO ---
def menu_gerenciamento():
    opcao_gerir = ""
    while opcao_gerir != '6':
        print("\n--- [GERENCIAMENTO] ---")
        print("1. Cadastrar | 2. Editar | 3. Remover | 4. Listar | 5. Buscar | 6. Voltar")
        
        opcao_gerir = input("\nEscolha: ")
        
        match opcao_gerir:
            case '1': print(">> Inserindo novo eleitor no MySQL...") 
            case '2': print(">> Alterando dados...")
            case '3': print(">> Removendo registro...")
            case '4': print(">> Consultando lista via Python...") 
            case '5': print(">> Localizando eleitor...")
            case '6': print(">> Voltando...")
            case _: print("Opção inválida.")

# --- INÍCIO DO SISTEMA ---
def iniciar_sistema():
    escolha = ""
    while escolha != '3':
        print("\n=== SISTEMA DE VOTAÇÃO (Navegação do Mapa) ===")
        print("1. Gerenciamento")
        print("2. Votação")
        print("3. Sair")
        
        escolha = input("\nPara onde deseja ir? ")
        
        match escolha:
            case '1': menu_gerenciamento()
            case '2': menu_votacao()
            case '3': print("Encerrando...")
            case _: print("Escolha 1, 2 ou 3.")

#Essa linha serve para garantir que o sistema só comece a rodar se este arquivo for executado
if __name__ == "__main__":
    iniciar_sistema()